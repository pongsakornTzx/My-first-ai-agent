{
  "version": 2,
  "framework": null,
  "installCommand": "echo 'skip npm install — static site'",
  "buildCommand": "echo 'no build — serving static index.html'",
  "outputDirectory": ".",
  "functions": {
    "api/**/*.py": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
